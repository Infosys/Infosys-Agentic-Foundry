DEFAULT_MODEL_NAME="gpt-4o"

USE_OTEL_LOGGING=False  # Set it as True for OpenTelemetry Collector and tracing. (False in local system)

OTEL_EXPORTER_OTLP_TRACES_ENDPOINT="http://localhost:4318/v1/traces"
USE_HTTP=True
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT_HTTP="http://localhost:4320/v1/logs"
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT_GRPC="localhost:4319"
ENABLE_LOGGING=True
# ---- Authentication / JWT ----
# Strong random secret (32+ chars). Change in production; rotating requires re-issuing existing tokens.
AUTH_JWT_SECRET=CHANGE_ME_STRONG_SECRET_CHANGE_ME_STRONG_SECRET_CHANGE_ME_STRONG_SECRET
# Algorithm for JWT signing (e.g., HS256, HS512)
AUTH_JWT_ALGORITHM=HS256
# Access token lifetime in seconds (default 900 = 15 minutes)
AUTH_ACCESS_TOKEN_EXPIRE_SECONDS=900
# Refresh token lifetime in days (default 14)
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=14
# Enable or disable refresh token flow ("true" / "false")
AUTH_ENABLE_REFRESH_TOKENS=true
# For Handling secrets
SECRETS_MASTER_KEY="YgxV5LIe1oWCqRnsKSS/B/+K64gs+YPS7sw4k/PksIw="

# Disables ssl in postgres connection string for inference
DISABLE_SSL_FOR_CHAT_CONNECTIONS=True

# Database name to be used
FEEDBACK_LEARNING_DB_NAME=feedback_learning
EVALUATION_LOGS_DB_NAME=evaluation_logs
RECYCLE_DB_NAME=recycle
LOGIN_DB_NAME=login
ARIZE_TRACES_DB_NAME=arize_traces
# keep it 'low' for local devices, change it to 'medium' or 'high' for Server/VM
CONNECTION_POOL_SIZE="low"
DISABLE_SSL_FOR_CHAT_CONNECTIONS=True
ENABLE_ONBOARDING=False

PHOENIX_COLLECTOR_ENDPOINT="http://localhost:6006"
PHOENIX_GRPC_PORT="50051"

MODEL_SERVER_URL = "http://127.0.0.1:5500"
MODEL_SERVER_HOST= 127.0.0.1
MODEL_SERVER_PORT=5500
ENVIRONMENT = development

# Set your Knowledgebase Server Endpoint
KB_SERVER_ENDPOINT="http://localhost:8003"

